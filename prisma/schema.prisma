generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum HeroType {
  IMAGE
  VIDEO
}

enum FaqAnswerType {
  TEXT
  SHORT
  LIST
  STEPS
  COMPARISON
  TABLE
  DEFINITION
}

enum FaqIntentType {
  DEFINITION
  PRICING
  HOW_TO
  COMPARISON
  SHIPPING
  CARE
  RETURN_POLICY
  AVAILABILITY
  TROUBLESHOOTING
}

enum FaqFactCheckStatus {
  PENDING
  VERIFIED
  NEEDS_REVIEW
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromotionType {
  BOGO
  PERCENTAGE_DISCOUNT
  FLAT_DISCOUNT
  BUNDLE
  FREE_SHIPPING
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum PromotionConditionType {
  MIN_QTY
  MIN_CART_VALUE
  PRODUCT_INCLUDED
  CATEGORY_INCLUDED
  BRAND_INCLUDED
  USER_SEGMENT
  REGION
  PAYMENT_METHOD
  FIRST_ORDER_ONLY
}

enum PromotionTargetType {
  PRODUCT
  CATEGORY
  BRAND
}

enum PromotionBenefitType {
  PERCENTAGE_DISCOUNT
  FLAT_DISCOUNT
  BOGO
  FREE_SHIPPING
  BUNDLE
}

enum PromotionDiscountUnit {
  PERCENT
  AMOUNT
}

enum PromotionApplyTo {
  ORDER
  ITEM
  SHIPPING
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(VIEWER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  parentId  String?
  parent    Page?    @relation("PageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[]   @relation("PageChildren")
  hero      Hero?
  faqs      Faq[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, order])
}

model Hero {
  id                 String   @id @default(cuid())
  pageId             String   @unique
  page               Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type               HeroType
  backgroundImageUrl String?
  backgroundVideoUrl String?
  slogan             String?
  title              String
  subtitle           String?
  keyPoints          String[]
  isActive           Boolean  @default(true)
  order              Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Faq {
  id                String              @id @default(cuid())
  page_id           String
  page              Page                @relation(fields: [page_id], references: [id], onDelete: Cascade)
  question          String
  answer            String
  short_answer      String
  answer_type       FaqAnswerType
  intent_type       FaqIntentType
  seo_title         String
  seo_description   String
  slug              String
  schema_enabled    Boolean             @default(true)
  ai_summary        String
  entity_tags       String[]
  source_url        String
  fact_check_status FaqFactCheckStatus
  last_verified_at  DateTime
  context           String
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  @@unique([page_id, slug])
  @@index([page_id])
}

model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String?
  parent_id       String?
  parent          Category?  @relation("CategoryChildren", fields: [parent_id], references: [id], onDelete: Cascade)
  children        Category[] @relation("CategoryChildren")
  is_active       Boolean    @default(true)
  is_featured     Boolean    @default(false)
  show_on_homepage Boolean   @default(false)
  thumbnail_image String?
  banner_image    String?
  seo_title       String?
  seo_description String?
  order           Int        @default(0)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  @@index([parent_id, order])
}

model Product {
  id                String        @id @default(cuid())
  sku               String        @unique
  name              String
  slug              String        @unique
  short_description String?
  description       String?
  faq_json          Json?
  key_features      String[]
  materials         String[]
  specifications    Json?
  use_cases         String[]
  how_to_use        String?
  benefits          String[]
  problem_solved    String?
  brand_id          String
  category_id       String
  category          Category      @relation(fields: [category_id], references: [id], onDelete: Restrict)
  status            ProductStatus @default(DRAFT)
  is_featured       Boolean       @default(false)
  is_published      Boolean       @default(false)
  tags              String[]
  gender            String?
  age_group         String?
  material          String?
  tax_class         String?
  weight            Float?
  length            Float?
  width             Float?
  height            Float?
  variants          ProductVariant[]
  images            ProductImage[]
  seo               ProductSeo?
  translations      ProductTranslation[]
  faqs              ProductFaq[]
  reviews           ProductReview[]
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  @@index([category_id])
  @@index([brand_id])
  @@index([status, is_published])
}

model ProductVariant {
  id           String        @id @default(cuid())
  product_id   String
  product      Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  sku          String        @unique
  variant_name String
  price        Float
  sale_price   Float?
  stock_qty    Int           @default(0)
  attributes   Json
  barcode      String?
  is_default   Boolean       @default(false)
  status       ProductStatus @default(DRAFT)
  images       ProductImage[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@index([product_id])
  @@index([status, is_default])
}

model ProductImage {
  id          String         @id @default(cuid())
  product_id  String
  product     Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant_id  String?
  variant     ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  image_url   String
  alt_text    String?
  is_primary  Boolean        @default(false)
  sort_order  Int            @default(0)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([product_id, sort_order])
  @@index([variant_id])
  @@index([is_primary])
}

model ProductSeo {
  product_id       String  @unique
  product          Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  meta_title       String
  meta_description String
  meta_keywords    String?
  canonical_url    String?
  slug             String  @unique
  og_title         String?
  og_description   String?
  og_image         String?
  schema_json      Json?
}

model ProductTranslation {
  id                String  @id @default(cuid())
  product_id        String
  product           Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  lang_code         String
  name              String
  short_description String?
  description       String?
  seo_title         String?
  seo_description   String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@unique([product_id, lang_code])
  @@index([lang_code])
}

model ProductFaq {
  id         String  @id @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  question   String
  answer     String
  order      Int     @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([product_id, order])
}

model ProductReview {
  id                 String   @id @default(cuid())
  product_id         String
  product            Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  customer_name      String
  customer_image_url String?
  comment            String?
  image_urls         String[]
  video_urls         String[]
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@index([product_id])
}

model Promotion {
  id             String           @id @default(cuid())
  name           String
  code           String           @unique
  type           PromotionType
  status         PromotionStatus  @default(DRAFT)
  start_at       DateTime?
  end_at         DateTime?
  priority       Int              @default(0)
  stackable      Boolean          @default(false)
  usage_limit    Int?
  per_user_limit Int?
  conditions     PromotionCondition[]
  targets        PromotionTarget[]
  benefits       PromotionBenefit[]
  redemptions    PromotionRedemption[]
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  @@index([status, start_at, end_at])
  @@index([priority])
}

model PromotionCondition {
  id             String    @id @default(cuid())
  promotion_id   String
  promotion      Promotion @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  condition_type PromotionConditionType
  operator       String
  value          String
  extra_value    String?
  created_at     DateTime  @default(now())

  @@index([promotion_id])
  @@index([condition_type])
}

model PromotionTarget {
  id            String              @id @default(cuid())
  promotion_id  String
  promotion     Promotion           @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  target_type   PromotionTargetType
  target_id     String
  created_at    DateTime            @default(now())

  @@index([promotion_id])
  @@index([target_type, target_id])
}

model PromotionBenefit {
  id                  String               @id @default(cuid())
  promotion_id        String
  promotion           Promotion            @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  benefit_type        PromotionBenefitType
  discount_value      Float?
  discount_unit       PromotionDiscountUnit?
  max_discount_amount Float?
  buy_qty             Int?
  get_qty             Int?
  apply_to            PromotionApplyTo?
  created_at          DateTime             @default(now())

  @@index([promotion_id])
  @@index([benefit_type])
}

model PromotionRedemption {
  id              String    @id @default(cuid())
  promotion_id    String
  promotion       Promotion @relation(fields: [promotion_id], references: [id], onDelete: Cascade)
  user_id         String?
  order_id        String?
  redeemed_at     DateTime  @default(now())
  discount_amount Float?

  @@index([promotion_id])
  @@index([user_id])
  @@index([order_id])
}
